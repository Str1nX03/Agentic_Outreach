# ==========================================
# Cold Emailing Agent — Environment Variables
# ==========================================

# --- Groq LLM ---
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_api_key

# --- Gmail SMTP ---
# The Gmail address emails will be sent FROM
GMAIL_ADDRESS=your_email_id

# Gmail App Password (NOT your regular password)
# Steps to generate:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to App Passwords: https://myaccount.google.com/apppasswords
#   3. Create a new app password and paste the 16-char code below
GMAIL_APP_PASSWORD=your_app_password_of_16_characters

# --- Sender Info ---
# Your name as it will appear in the email template
SENDER_NAME=your_name
